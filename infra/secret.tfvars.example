# Copy to `secret.tfvars` (git-ignored) and fill in. These are the ONLY keys
# Azure can't generate; Terraform writes them into Key Vault. Every Azure key
# (Cosmos, Event Hub, Storage, Vision, Language) is generated + stored automatically.
#
#   terraform apply -var-file="secret.tfvars"

youtube_api_key           = "AIza...your-youtube-data-api-v3-key"
gemini_api_key            = "your-gemini-api-key"
pubsubhubbub_verify_token = "a-random-shared-secret"
