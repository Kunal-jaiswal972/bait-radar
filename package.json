{
  "name": "yt-data-analyzer",
  "version": "0.1.0",
  "description": "Serverless, event-driven YouTube analytics pipeline on Azure Functions (v4 Node.js model)",
  "main": "dist/src/functions/*.js",
  "scripts": {
    "build": "rimraf dist && tsc",
    "watch": "tsc -w",
    "clean": "rimraf dist",
    "prestart": "bun run build",
    "start": "func start"
  },
  "dependencies": {
    "@azure-rest/ai-vision-image-analysis": "^1.0.0-beta.3",
    "@azure/ai-language-text": "^1.1.0",
    "@azure/core-auth": "^1.10.1",
    "@azure/cosmos": "^4.2.0",
    "@azure/event-hubs": "^5.12.0",
    "@azure/functions": "^4.6.0",
    "@google/generative-ai": "^0.24.1",
    "xml2js": "^0.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/xml2js": "^0.4.14",
    "rimraf": "^5.0.0",
    "typescript": "^5.5.0"
  }
}
