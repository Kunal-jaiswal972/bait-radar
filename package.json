{
  "name": "yt-data-analyzer",
  "version": "0.1.0",
  "description": "Serverless, event-driven YouTube analytics pipeline on Azure Functions (v4 Node.js model)",
  "main": "dist/src/functions/**/*.js",
  "scripts": {
    "build": "rimraf dist && tsc",
    "watch": "tsc -w",
    "clean": "rimraf dist",
    "prestart": "bun run build",
    "start": "func start",
    "backfill": "bun run src/scripts/backfill.ts",
    "migrate": "bun run src/scripts/migrate.ts"
  },
  "dependencies": {
    "@azure/ai-language-text": "^1.1.0",
    "@azure/cosmos": "^4.2.0",
    "@azure/functions": "^4.6.0",
    "@azure/storage-queue": "^12.31.0",
    "@google/generative-ai": "^0.24.1",
    "xml2js": "^0.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/xml2js": "^0.4.14",
    "rimraf": "^5.0.0",
    "typescript": "^5.5.0"
  }
}
